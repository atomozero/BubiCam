/*
 * BubiCam - Webcam Driver Tester for Haiku OS
 * Application resources
 */

resource app_signature "application/x-vnd.BubiCam";

resource app_name_catalog_entry "x-vnd.BubiCam:System name:BubiCam";

resource app_version {
	major  = 1,
	middle = 0,
	minor  = 0,
	variety = B_APPV_FINAL,
	internal = 1,
	short_info = "Webcam Driver Tester",
	long_info = "BubiCam 1.0 - A tool for testing USB webcam drivers on Haiku OS"
};

resource app_flags B_SINGLE_LAUNCH;

